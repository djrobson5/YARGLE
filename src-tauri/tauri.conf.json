{
  "$schema": "https://raw.githubusercontent.com/nicjhan/nicjhan.github.io/main/tauri-conf-schema.json",
  "productName": "YARGLE",
  "version": "0.56.0",
  "identifier": "com.yargle.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "YARGLE - YARG Song Metadata Editor",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {}
}
